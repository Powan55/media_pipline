# --- Dual-track topic engine (added 2026-06-21) ----------------------------
# The second daily slot can draw from a GENERAL-TECH track (broad consumer tech +
# crazy-tech-story lead) instead of a second AI-vendor pick. This whole block is
# OPTIONAL — absent or disabled, the pipeline runs single-track exactly as before.
#
# ONE-FLIP ROLLBACK: set dual_track_enabled: false to revert /start -auto to two
# AI-vendor picks. start.md honors this flag.
tracks:
  dual_track_enabled: true              # ENABLED 2026-06-23 (operator-directed): slot 2 = general-tech every /start -auto. Flip false for one-flip rollback to two AI-vendor picks.
  general_tech:
    weights_path: scoring_weights_general_tech.json  # per-track scoring profile (blank -> convention default)
    idea_prompt: 02_idea_generation_general_tech      # idea-gen prompt name for this track
    fact_check_prompt: 05_fact_check_general_tech      # apex sets fact_check.prompt to this in the GT sub-agent's isolated config
    suppress_ai_vendor_bonus: true                     # don't reward AI-vendor mentions on the general-tech track
    slot: 2                                             # pilot: GT -> slot 2 (12:35 PM ET, experimental); ai-vendor -> slot 1 (control)

news_rss:
  # Gate for the general-tech RSS poll (tools/news_rss_poller.py --track general-tech).
  # The poller itself is config-free; the orchestration layer (start.md / the
  # scheduled task) reads this flag to decide whether to run the general-tech poll.
  general_tech_feeds_enabled: true   # ENABLED 2026-06-23 with dual_track_enabled: feed the general-tech RSS poll in /start -auto step 4d

# --- Self-improving feedback loop (added 2026-06-23) ------------------------
# Closed measurement loop: captures matured analytics, learns reach-first, and
# AUTO-APPLIES ONLY reversible non-sacred config knobs within bounded deltas
# (auto-reverting on regression). Sacred gates + scoring-component weights are
# PROPOSE-only via the weekly review. The whole block is OPTIONAL — absent or
# disabled, the pipeline runs exactly as before. The core is deterministic
# Python statistics over data the pipeline already writes — no API, no agent
# framework. See Documents/Project plan + _pipeline/learning/.
learning:
  enabled: true                 # master switch (telemetry capture + read-only analysis)
  apply_enabled: true           # DEFAULT ON 2026-06-24 (operator-directed): the loop AUTO-APPLIES <=1
                                # bounded, reversible, non-sacred knob/run during /start -auto, opened as a
                                # tracked experiment with auto-rollback on regression. Sacred gates untouched.
                                # Flip false for report/propose-only.
  maturity_floor_days: 2        # only learn from videos this many days live (analytics need ~48h)
  min_views_floor: 70           # a matured row needs >= this many views to count as a datapoint
  min_sample: 5                 # minimum cohort size per feature before any auto-tune
  retention_floor_pct: 25.0     # never auto-tune so that cohort-median avg_view_pct drops below this
  max_active_experiments: 2     # global cap on simultaneously-open auto-experiments
  max_auto_applies_per_cycle: 1 # at most this many safe knobs auto-applied per loop run
  repair_csv_header: false      # OPERATOR-GATED: rewrite the legacy 12-col analytics header to the
                                # canonical 15-col form. Default false — the loop reads correctly via a
                                # positional loader regardless, so this is cosmetic for other DictReader
                                # consumers. Touches the canonical analytics file; a .bak is taken.

logging:
  level: INFO                           # DEBUG | INFO | WARNING | ERROR
  format: "%(asctime)s [%(levelname)s] %(name)s: %(message)s"
  per_run_subdir: true                  # each pipeline run gets its own logs/ subfolder
