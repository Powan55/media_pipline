  # Channel IDs / handles — fill in after creating the platform accounts.
  youtube_channel_id: <<TODO>>
  tiktok_username:    <<TODO>>
  instagram_username: <<TODO>>
  output_path: C:\ContentOps\channels\ShadowVerse\01_research\_weekly_analytics.csv

logging:
  level: INFO                           # DEBUG | INFO | WARNING | ERROR
  format: "%(asctime)s [%(levelname)s] %(name)s: %(message)s"
  per_run_subdir: true                  # each pipeline run gets its own logs/ subfolder
