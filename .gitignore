# =====================================================================
# Top-level gitignore for media_pipline.
# The pipeline/ subdir has its own .gitignore that mirrors most of this;
# rules here apply repo-wide.
# =====================================================================

# --- Secrets (NEVER commit) ---
.env
.env.local
.env.*.local
*.key
*.pem
**/credentials/*
!**/credentials/.gitkeep
!**/credentials/README.md

# --- Real configs (templates only are committed) ---
**/config.yaml
**/config.local.yaml

# --- Operator-only state (per durable rules) ---
SESSION_HANDOFF.md
TODO.md
TODO_archive*.md
.research/
**/postmortems/
**/analysis/
**/leaderboards/
**/_weekly_analytics.csv
hook_selection_backfill_unresolved.csv

# --- Logs & runtime artifacts ---
**/logs/*
!**/logs/.gitkeep
*.log
.run_logs/

# --- Local Claude Code / IDE config ---
.claude/
.vscode/
.idea/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# --- Build artifacts ---
dist/
build/
*.egg-info/

# --- Editor / OS ---
*.swp
.DS_Store
Thumbs.db
desktop.ini

# --- Models (never in code repo) ---
*.bin
*.gguf
*.pt
*.pth
*.safetensors
*.ckpt
*.onnx

# --- Media (belongs in channels/ on disk, never in repo) ---
*.mp4
*.mov
*.mkv
*.webm
*.wav
*.mp3
*.flac
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.srt
*.ass
*.vtt

# --- Graphify output (per-machine) ---
graphify-out/
